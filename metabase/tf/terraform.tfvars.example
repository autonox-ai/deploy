# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# --- Metabase admin credentials (created during the first-login flow) ---
metabase_host     = "http://localhost:3000"
metabase_username = "admin@example.com"
metabase_password = "REPLACE_ME"

# --- AutoNox PostgreSQL connection that Metabase uses to read bi_views ---
pg_host     = "host.docker.internal"   # or "postgres" / "nox-pg18" if on autonox-local network
pg_port     = 5432
pg_database = "autonox"
pg_user     = "bireader"
pg_password = "REPLACE_ME"
pg_ssl      = false
