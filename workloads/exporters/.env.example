# exporters workload — configuration
# Copy to .env and fill in.

# --- AutoNox warehouse connection ---
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=autonox
PG_USER=noxop
PG_PASSWORD=

# --- Optional: override the image (e.g. JFrog virtual repo rewrite) ---
# EXPORTERS_IMAGE=artifactory.example.com/autonox-virtual/autonox-ai/exporters:1.2.0

# --- Source system credentials (per-exporter; fill in the ones you use) ---
# OKTA_API_TOKEN=
# AD_USER=
# AD_PASSWORD=
